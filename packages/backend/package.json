{
  "name": "@discode/backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && dotenvx run -f .env -- node dist/src/server.js",
    "lint": "eslint . --fix",
    "pretty": "prettier --write .",
    "db:start": "docker compose up -d database",
    "db:migrate:make": "kysely migrate:make ",
    "db:migrate:up": "dotenvx run -f .env -- kysely migrate:up",
    "db:migrate:down": "dotenvx run -f .env -- kysely migrate:down",
    "db:migrate:latest": "dotenvx run -f .env -- kysely migrate:latest",
    "db:rollback": "dotenvx run -f .env -- kysely migrate:rollback",
    "db:seed:run": "dotenvx run -f .env -- kysely seed:run",
    "db:seed:make": "kysely seed:make"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "kysely-ctl": "^0.20.0",
    "npm": "^11.12.0",
    "prettier": "3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.57.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "kysely": "^0.28.14",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  }
}
