# When adding new environment variables, be sure to also update the file://./src/types/global.d.ts file.
PORT=3000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

############################
# PostgreSQL Configuration
############################
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB_NAME=discode
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

############################
# Azure Storage Blob
############################
# These values are used for local Azurite, the well-known account name and key are used by default.
# Reference: https://learn.microsoft.com/en-us/azure/storage/common/storage-connect-azurite
# Endpoint format in production: `https://${process.env.AZURE_ACCOUNT_NAME}.blob.core.windows.net`
AZURE_STORAGE_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1/azurite
AZURE_ACCOUNT_NAME=devstoreaccount1
AZURE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==

############################
# Azure Service Bus
############################
# These values are for local development with the Azure Service Bus emulator. In production, use the actual connection string from your Azure Service Bus instance.
# Reference: https://learn.microsoft.com/en-us/azure/service-bus-messaging/test-locally-with-service-bus-emulator?tabs=docker-linux-container#choosing-the-right-connection-string
AZURE_SERVICE_BUS_CONNECTION_STRING="Endpoint=sb://localhost;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SAS_KEY_VALUE;UseDevelopmentEmulator=true;"
AZURE_SUBMISSIONS_QUEUE_NAME=submission-execution
