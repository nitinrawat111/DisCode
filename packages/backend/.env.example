# When adding new environment variables, be sure to also update the file://./src/types/global.d.ts file.
PORT=3000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

############################
# PostgreSQL Configuration
############################
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB_NAME=discode
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

############################
# Azure Storage Blob
############################
AZURE_ACCOUNT_NAME=<account_name>
AZURE_ACCOUNT_KEY=<account_key>

############################
# Azure Service Bus
############################
AZURE_SERVICE_BUS_CONNECTION_STRING=<connection_string>
AZURE_SERVICE_BUS_QUEUE_NAME=code-execution
